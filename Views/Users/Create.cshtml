@model CustomerList.Models.ViewModels.CreateUserViewModel

@{
    ViewData["Title"] = "Create User";
    var roles = ViewBag.Roles as List<string> ?? new List<string>();
}

<div class="customer-page">
    <a asp-action="Index" class="back-link">&larr; Back to user list</a>

    <div class="details-header">
        <h1>Create User</h1>
    </div>

    <div class="customer-table-card" style="padding: 24px 28px; max-width: 480px;">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="customer-error" style="display: block;"></div>

            <div class="filter-field" style="margin-bottom: 16px;">
                <label asp-for="Email"></label>
                <input asp-for="Email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="filter-field" style="margin-bottom: 16px;">
                <label asp-for="Password"></label>
                <input asp-for="Password" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="filter-field" style="margin-bottom: 16px;">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <div class="filter-field" style="margin-bottom: 20px;">
                <label asp-for="Role"></label>
                <select asp-for="Role">
                    <option value="">-- Select a role --</option>
                    @foreach (var role in roles)
                    {
                        <option value="@role">@role</option>
                    }
                </select>
                <span asp-validation-for="Role" class="field-error"></span>
            </div>

            <button type="submit" class="btn-primary">Create User</button>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}